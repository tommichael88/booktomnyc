        function _computePrice(svc, answers, qty) {
            const base = svc.financial_engine?.base_price || svc.base_price || 0;
            let extraFee = 0,
                extraMin = 0,
                matMin = 0,
                matMax = 0;
            const tags = DB.smart_tags || {};
            const allMods = _resolveIntakeChain(svc);
            const mods = allMods.filter(m => answers[m.moduleKey]);
            mods.forEach(mod => {
                const resp = (mod.client_response || []).find(r => r.label === answers[mod.moduleKey]);
                if (resp?.effects?.fee) extraFee += resp.effects.fee;
                if (resp?.effects?.minutes) extraMin += resp.effects.minutes;
            });
            const detAndMan = [...new Set([...S.detTagIds, ...S.manTagIds])].filter(tid => !S.negatedTagIds.includes(
            tid));
            detAndMan.forEach(tid => {
                const t = tags[tid];
                if (t?.fee) extraFee += t.fee;
                if (t?.effects?.fee) extraFee += t.effects.fee;
                if (t?.effects?.minutes) extraMin += t.effects.minutes;
            });
            const om = svc.operational_metrics || {};
            const expected = om.expected_minutes || 60;
            const tier = om.complexity_tier || 'skilled';
            const rate = DB.global_rules?.complexity_tiers?.[tier]?.hourly_rate || 85;
            const totalMin = expected + extraMin;
            const labor = Math.round((base + extraFee + (totalMin / 60) * rate) * qty);
            const de = svc.default_estimates || {};
            if (de.materials) { matMin = de.materials.min || 0;
                matMax = de.materials.max || 0; }
            return { laborEstimate: labor, extraFee, extraMin, totalMin, complexityOverride: tier, tierRate: rate,
                matMin, matMax };
        }


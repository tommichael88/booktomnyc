            let m = text.match(new RegExp('\\b(\\d+)\\s*(?:' + UNITS + ')', 'i'));
            if (m) return Math.min(parseInt(m[1]), 99);
            const wmap = { one: 1, two: 2, three: 3, four: 4, five: 5, six: 6, seven: 7, eight: 8, nine: 9, ten: 10 };

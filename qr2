    <style>
        /* ─── base ──────────────────────────────────────────────────────────── */
        :root {
            --clr-red: #de0000;
            --clr-red-dark: #8a0615;
            --clr-white-10: #ffffff1a;
            --clr-white-15: #ffffff26;
            --clr-white-20: #fff3;
            --clr-white-25: #ffffff40;
            --clr-black-55: #ffffff8c;
            --clr-black-65: #ffffffa6;
            --clr-black-75: #ffffffbf;
            --clr-silver: #c0c0c080;
            --glass-bg: #ffffff26;
            --glass-border: .5px solid #c0c0c0f2;
            --glass-blur: blur(14px);
            --glass-shadow: 0 4px 24px #000000bf;
            --var-glass-bg: #ffffff80;
            --radius-sm: 10px;
            --radius-md: 15px;
            --radius-lg: 16px;
            --transition: all .25s cubic-bezier(.4, 0, .2, 1);
            --touch-min: 44px;
            --step-idle: #ffffff2e;
            --step-active: var(--clr-black-65);
            --step-done: var(--clr-black-65);
            --color-bg-card: #FFF;
            --color-bg-subtle: #FAFAFA;
            --color-bg-hover: #F1F5F9;
            --color-success: #000;
            --color-success-light: #ECFDF5;
            --color-success-border: #A7F3D0;
            --color-success-text: #065F46;
            --color-danger: #EF4444;
            --color-danger-light: #FEF2F2;
            --color-danger-border: #FECACA;
            --color-danger-text: #991B1B;
            --color-border: #E2E8F0;
            --color-border-focus: #93C5FD;
            --shadow-sm: 0 1px 2px 0 #0000000d;
            --shadow-md: 0 4px 6px -1px #0000000d 0 2px 4px -1px #00000008;
            --shadow-lg: 0 10px 15px -3px #0000000d 0 4px 6px -2px #00000006;
            --radius-pill: 9999px;
            font-family: Ubuntu, -apple-system, BlinkMacSystemFont, sans-serif;
            --color-bg-body: #F4F4F5;
            -webkit-text-size-adjust: 100%
        }

        *,
        ::after,
        ::before {
            box-sizing: border-box
        }

        body {
            font-family: Roboto, Ubuntu, -apple-system, BlinkMacSystemFont, sans-serif;
            padding: 10px;
            min-height: 100vh;
            height: calc(var(--vh, 1vh)*100);
            overflow-x: hidden;
            position: relative;
            background: #fff;
            touch-action: manipulation;
            -webkit-tap-highlight-color: #fff;
            margin: 0
        }

        body.modal-active {
            overflow: hidden
        }

        .pg_background {
            position: fixed;
            inset: 0;
            z-index: 0;
            height: 100vh;
            background-size: cover;
            background-attachment: fixed;
            background-position: center top;
            background-image: url(https://github.com/tommichael88/booktomnyc/blob/main/images/pg_background7.png?raw=true);
            backdrop-filter: #fff;
            -webkit-backdrop-filter: #fff
        }

        /* ═══ GSAP ENHANCEMENTS ═══ */
        .gsap-fade-in {
            opacity: 0;
            transform: translateY(30px) scale(0.96);
        }

        .gsap-fade-in.done {
            opacity: 1 !important;
            transform: translateY(0) scale(1) !important;
        }

        .gsap-stagger-children>* {
            opacity: 0;
            transform: translateY(24px) scale(0.95);
        }

        .gsap-stagger-children.done>* {
            opacity: 1 !important;
            transform: translateY(0) scale(1) !important;
        }

        .gsap-float {
            animation: gsapFloat 4s ease-in-out infinite;
        }

        @keyframes gsapFloat {
            0%,
            100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-14px);
            }
        }

        .gsap-glow-pulse {
            animation: gsapGlowPulse 2.4s ease-in-out infinite;
        }

        @keyframes gsapGlowPulse {
            0%,
            100% {
                box-shadow: 0 0 12px rgba(222, 0, 0, 0.2), 0 0 40px rgba(222, 0, 0, 0.05);
            }
            50% {
                box-shadow: 0 0 28px rgba(222, 0, 0, 0.45), 0 0 70px rgba(222, 0, 0, 0.15);
            }
        }

        .gsap-tilt-3d {
            transition: transform 0.08s ease-out;
            will-change: transform;
        }

        .gsap-magnetic {
            transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
            will-change: transform;
        }

        .gsap-magnetic:hover {
            transform: scale(1.08) translateY(-4px);
        }

        /* category cards enhanced hover */
        .category-card {
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.4s ease,
                border-color 0.3s ease;
            will-change: transform;
            backface-visibility: hidden;
        }

        .category-card:hover {
            transform: translateY(-10px) scale(1.03) rotate(1deg);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15), 0 0 0 2px rgba(222, 0, 0, 0.15);
            border-color: rgba(222, 0, 0, 0.3);
        }

        .category-card .category-icon {
            transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .category-card:hover .category-icon {
            transform: scale(1.18) rotate(-4deg);
        }

        /* profile image enhanced */
        .profile-portrait-image {
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.4s ease;
            will-change: transform;
            cursor: default;
            border-radius: 16px;
        }

        .profile-portrait-image:hover {
            transform: scale(1.02) rotate(1.5deg);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2), 0 0 30px rgba(222, 0, 0, 0.06);
        }

        /* contact button enhanced */
        .contact-button {
            transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.4s ease,
                background 0.4s ease;
            will-change: transform;
        }

        .contact-button:hover {
            transform: scale(1.15) rotate(3deg) !important;
        }

        /* step dots enhanced */
        .step-dot {
            transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
            will-change: transform, background, border-color, box-shadow;
        }

        .step-dot.active {
            animation: stepPulse 1.8s ease-in-out infinite;
        }

        .step-connector {
            transition: background 0.6s ease, transform 0.4s ease;
            will-change: transform, background;
        }

        .step-connector.done {
            transform: scaleX(1);
        }

        /* service tiles enhanced */
        .service-tile {
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.4s ease,
                border-color 0.3s ease;
            will-change: transform;
        }

        .service-tile:hover {
            transform: translateY(-6px) scale(1.02);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.1), 0 0 0 2px rgba(222, 0, 0, 0.1);
        }

        /* cart FAB enhanced */
        #cartFab {
            transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.5s ease,
                background 0.4s ease;
            will-change: transform;
        }

        #cartFab:hover {
            transform: scale(1.12) rotate(6deg);
            box-shadow: 0 8px 30px rgba(138, 6, 21, 0.5), 0 0 40px rgba(222, 0, 0, 0.2);
        }

        /* highlight box enhanced */
        .highlight-box {
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.4s ease;
            will-change: transform;
        }

        .highlight-box:hover {
            transform: translateY(-3px) scale(1.005);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
        }

        /* booking step bar enhanced */
        .booking-step-bar {
            transition: opacity 0.5s ease, transform 0.5s ease;
            will-change: transform, opacity;
        }

        /* smart quote live preview enhanced */
        .sq-live-preview {
            transition: all 0.3s ease;
            will-change: transform, opacity;
        }

        .sq-live-preview .preview-phrase {
            display: inline-block;
            transition: color 0.3s ease;
        }

        /* main card enhanced */
        .main-card-schedule-service {
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.4s ease;
            will-change: transform;
        }

        /* floating particles background overlay */
        #particles-canvas {
            position: fixed;
            inset: 0;
            z-index: 1;
            pointer-events: none;
            opacity: 0.35;
            mix-blend-mode: screen;
        }

        /* loading screen */
        #gsap-loader {
            position: fixed;
            inset: 0;
            z-index: 99999;
            background: #0a0a0a;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-family: Ubuntu, sans-serif;
            transition: opacity 0.8s ease, visibility 0.8s ease;
        }

        #gsap-loader.hidden {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }

        #gsap-loader .loader-ring {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            border: 3px solid rgba(255, 255, 255, 0.06);
            border-top-color: #de0000;
            border-right-color: #8a0615;
            animation: loaderSpin 1s linear infinite;
            margin-bottom: 28px;
            box-shadow: 0 0 40px rgba(222, 0, 0, 0.15);
        }

        #gsap-loader .loader-text {
            font-size: 1.1rem;
            font-weight: 600;
            letter-spacing: 0.15em;
            opacity: 0.7;
        }

        #gsap-loader .loader-dots::after {
            content: '...';
            animation: loaderDots 1.4s steps(4, end) infinite;
        }

        @keyframes loaderSpin {
            to {
                transform: rotate(360deg);
            }
        }

        @keyframes loaderDots {
            0% {
                content: '';
            }
            25% {
                content: '.';
            }
            50% {
                content: '..';
            }
            75% {
                content: '...';
            }
        }

        /* responsive touch-ups */
        @media (max-width: 600px) {
            .gsap-stagger-children>* {
                transform: translateY(16px) scale(0.97);
            }
            .category-card:hover {
                transform: translateY(-6px) scale(1.02) rotate(0.5deg);
            }
            .profile-portrait-image:hover {
                transform: scale(1.01) rotate(0.5deg);
            }
            .contact-button:hover {
                transform: scale(1.06) rotate(1deg) !important;
            }
        }

        /* scroll-trigger reveal helpers */
        .reveal-left {
            opacity: 0;
            transform: translateX(-40px) scale(0.96);
        }
        .reveal-right {
            opacity: 0;
            transform: translateX(40px) scale(0.96);
        }
        .reveal-up {
            opacity: 0;
            transform: translateY(40px) scale(0.96);
        }
        .reveal-scale {
            opacity: 0;
            transform: scale(0.85);
        }

        /* all existing styles below are preserved — scroll for full CSS */
        .qrc_page_inner {
            max-width: 700px;
            margin: auto;
            padding: 4px 4px 80px;
            position: relative;
            z-index: 9
        }

        .profile-portrait-image {
            display: block;
            width: 100%;
            height: auto;
            border-radius: 10px;
            margin: 2px auto;
            transition: transform .4s cubic-bezier(.34, 1.56, .64, 1);
            box-shadow: 15px 15px 30px #bebebe, -15px -15px 30px #fff;
        }

        .highlight-box {
            display: flex;
            width: 100%;
            justify-content: space-between;
            align-items: center;
            padding: 12px 15px;
            gap: 2%;
            background: var(--glass-bg);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            box-shadow: inset 0 1px 2px #ffffff26 0 2px 12px #0006;
            border: var(--glass-border);
            border-radius: var(--radius-sm);
            transition: var(--transition)
        }

        .thandylogo {
            max-height: 5rem;
            width: auto;
            flex: 0 0 auto;
            object-fit: contain
        }

        .tmk_signature {
            flex: 1 1 auto;
            min-width: 0;
            margin: auto;
            position: relative;
            filter: drop-shadow(0 2px 4px #0000004d)
        }

        .tmk_signature img {
            width: auto;
            max-width: 100%;
            filter: drop-shadow(0 2px 4px #0000004d)
        }

        .contact-button {
            position: relative;
            isolation: isolate;
            z-index: 2;
            min-width: 64px;
            min-height: 36px;
            padding: 8px 12px;
            font-size: .85rem;
            font-weight: 700;
            color: #fff;
            background: #000000bf;
            border: 1px solid #ffffff4d;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
            box-shadow: inset 0 1px 2px #ffffff40 inset 0 -1px 2px #0006;
            overflow: visible
        }

        .contact-button .contact-glow-ring,
        .contact-button .contact-sparkle,
        .contact-button::after,
        .contact-button::before {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0);
            opacity: 0;
            transition: all .4s cubic-bezier(.34, 1.56, .64, 1);
            pointer-events: none;
            z-index: -1
        }

        .contact-button::before {
            width: 4.2rem;
            height: 4.2rem;
            background: radial-gradient(circle at 30% 30%, #ffffffe6 2%, transparent 4%), radial-gradient(circle at 70% 20%, #fffc 3%, transparent 5%), radial-gradient(circle at 20% 70%, #ffffffb3 2%, transparent 4%), radial-gradient(circle at 80% 80%, #fff9 3%, transparent 5%), radial-gradient(circle, #ffffff40 0, #ffffff26 25%, #ffffff14 50%, transparent 80%);
            border: 1.5px solid #fff9;
            clip-path: polygon(50% 0, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
            filter: blur(.5px) drop-shadow(0 0 8px #fff9)
        }

        .contact-button::after {
            width: 3.6rem;
            height: 3.6rem;
            background: radial-gradient(circle at 50% 50%, #fff6 0, #fff3 30%, #ffffff1a 50%, transparent 70%);
            clip-path: polygon(50% 0, 58% 32%, 95% 32%, 65% 54%, 76% 88%, 50% 67%, 24% 88%, 35% 54%, 5% 32%, 42% 32%);
            filter: blur(1px);
            mix-blend-mode: screen
        }

        .contact-button .contact-glow-ring {
            width: 4.8rem;
            height: 4.8rem;
            border-radius: 50%;
            border: 1px solid #fff6;
            box-shadow: 0 0 20px #ffffff80 inset 0 0 20px #ffffff4d
        }

        .contact-button:hover {
            transform: scale(1.4) rotate(5deg);
            background: radial-gradient(circle at 10% 60%, #8a0615 0, #de0000 40%, #de0000 60%, #8a0615 90%);
            border-color: #ff00004d;
            box-shadow: 0 4px 20px #8a061566 0 0 0 1px #ffffff26 inset 0 1px 0 #fff3 0 0 30px #ff00004d;
            color: #fff;
            text-shadow: 0 0 12px #de0000cc 0 0 20px #de000066 0 0 30px #de000033
        }

        .contact-button:hover::before {
            transform: translate(-50%, -50%) scale(1);
            opacity: 1;
            animation: starSpin 8s linear infinite, contactStarPulse 2s ease-in-out infinite
        }

        .contact-button:hover::after {
            transform: translate(-50%, -50%) scale(1);
            opacity: .7;
            animation: starSpinReverse 12s linear infinite
        }

        .contact-button:hover .contact-glow-ring {
            transform: translate(-50%, -50%) scale(1);
            opacity: .8;
            animation: contactRingPulse 3s ease-in-out infinite
        }

        .contact-button:active {
            transform: scale(.95) rotate(-5deg)
        }

        .contact-toolbar {
            display: none;
            animation: slideDown .6s ease;
            transition: var(--transition)
        }

        .contact-toolbar.active {
            display: flex;
            width: 100%;
            justify-content: space-between;
            padding: 5px;
            background: var(--glass-bg);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            box-shadow: inset 0 1px 2px #ffffff26 0 2px 12px #0006;
            border: 1.5px solid #a9a9a9b3;
            border-radius: 5px;
            position: relative
        }

        .contact-toolbar-item {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-width: 70px;
            min-height: var(--touch-min);
            padding: 10px 12px;
            background: #c8c8c8d9;
            border: 1px solid #a9a9a9b3;
            border-radius: var(--radius-md);
            text-decoration: none;
            font-weight: 800;
            cursor: pointer;
            transition: var(--transition);
            color: #000;
            overflow: hidden
        }

        .contact-toolbar-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, #00000026, transparent);
            transition: left .6s ease;
            pointer-events: none
        }

        .contact-toolbar-item:hover::before {
            left: 100%
        }

        .contact-toolbar-item:hover {
            background: #fffffff2;
            transform: translateY(-3px) scale(1.05);
            border-color: #0000004d
        }

        .contact-toolbar-icon {
            color: var(--clr-red);
            font-size: 2rem;
            margin-bottom: 6px;
            transition: var(--transition)
        }

        .contact-toolbar-item:hover .contact-toolbar-icon {
            transform: scale(1.5) rotate(5deg)
        }

        .contact-toolbar-label {
            font-size: .75rem;
            font-weight: 700;
            text-align: center
        }

        .contact-toolbar.active .contact-toolbar-item {
            opacity: .7;
            transform: scale(.95);
            transition: none
        }

        .contact-toolbar.active .contact-toolbar-item:nth-child(1) {
            animation: lightUpItem .4s ease .1s forwards, itemPulse 2s ease-in-out 1.2s infinite
        }

        .contact-toolbar.active .contact-toolbar-item:nth-child(2) {
            animation: lightUpItem .4s ease .3s forwards, itemPulse 2s ease-in-out 1.4s infinite
        }

        .contact-toolbar.active .contact-toolbar-item:nth-child(3) {
            animation: lightUpItem .4s ease .5s forwards, itemPulse 2s ease-in-out 1.6s infinite
        }

        .contact-toolbar.active .contact-toolbar-item:nth-child(4) {
            animation: lightUpItem .4s ease .7s forwards, itemPulse 2s ease-in-out 1.8s infinite
        }

        .contact-toolbar.active::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            height: 3px;
            background: linear-gradient(90deg, #8a0615 0, #de0000 25%, red 50%, #8a0000 75%, #000 100%);
            border-radius: 0 0 10px;
            z-index: 1;
            width: 100%
        }

        #cartFab {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            min-width: 64px;
            min-height: 64px;
            padding: 10px 14px;
            background: linear-gradient(135deg, #8a0615 0, #b80a1f 100%);
            border: 2px solid #ffffff1a;
            border-radius: 15px;
            box-shadow: 0 4px 20px #8a061566 0 0 0 1px #ffffff26 inset 0 1px 0 #fff3 0 0 30px #ffd7004d;
            backdrop-filter: blur(4px);
            cursor: pointer;
            overflow: visible;
            transition: all .4s cubic-bezier(.34, 1.56, .64, 1);
            z-index: 1000
        }

        #cartFab::before {
            content: "";
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 4.8rem;
            height: 4.8rem;
            background: radial-gradient(circle at 30% 30%, #ffffffe6 2%, transparent 4%), radial-gradient(circle at 70% 20%, #fffc 3%, transparent 5%), radial-gradient(circle, #ffdf0040 0, #ffd70026 25%, #ffd70014 50%, transparent 80%);
            border: 2px solid #ffd70099;
            clip-path: polygon(50% 0, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
            filter: blur(.5px) drop-shadow(0 0 10px #ffd70099);
            animation: starSpin 8s linear infinite, starPulse 3s ease-in-out infinite;

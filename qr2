        function sqBuilderRender() {
            const stepDef = sqBuilderCurrentStep();
            if (!stepDef) { sqBuilderFinish(); return; }

            const allSteps = sqBuilderGetSteps();
            const totalSteps = allSteps.length;

            const choices = typeof stepDef.choices === 'function' ? stepDef.choices(BLD) : stepDef.choices;

            if (!choices || choices.length === 0) { BLD.step++;
                sqBuilderRender(); return; }

            sqBuilderUpdateSentence();


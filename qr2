                tierKey,
                tierRate,
                laborCalc,
                dispatch,
                checkoutStateKey,
                isDiag,
                isProject,
                priceDisplay,
                priceSub,
                disclaimerText: disclaimer,
                hideTime,
                btnText,
                activeLabels,
                isAssembly: false,
                meetsConfidenceBar: true,
            };
        }

        function bldGroupToKeyword(groupId, categoryId) {
            const g = groupMap.get(groupId);
            if (g) return g.display_name || g.name;
            return groupId;
        }

        function stDefaultAction(stype) {
            const map = {
                'Install': 'install',
                'Install / Mount': 'mount',
                'Repair': 'fix',
                'Diagnostic': 'look at',
                'Assembly': 'assemble',
                'Setup': 'set up'
            };
            return map[stype] || 'fix';
        }

        function sqBuilderGetSteps() {
            const steps = ['action'];
            if (!BLD.action) return steps;
            // Actions without a clear object (e.g. just "I need help" → skip object step)
            steps.push('object');
            if (BLD.object) steps.push('specific');
            steps.push('condition');
            if (!BLD.condition) steps.push('location');
            return steps;
        }

        function sqBuilderCurrentStep() {
            const steps = sqBuilderGetSteps();
            if (BLD.step >= steps.length) return null;
            const sid = steps[BLD.step];
            const stepDefs = {
                action: {
                    id: 'action',
                    icon: 'ti-wrench',
                    prompt: 'What do you need done?',
                    choices: (ctx) => {
                        const base = [
                            { value: 'fix', label: 'Fix / Repair', icon: 'ti-tools', stype: 'Repair' },
                            { value: 'install', label: 'Install', icon: 'ti-plug', stype: 'Install' },
                            { value: 'mount', label: 'Mount', icon: 'ti-wall', stype: 'Install / Mount' },
                            { value: 'assemble', label: 'Assemble', icon: 'ti-puzzle', stype: 'Assembly' },
                            { value: 'set up', label: 'Set up / Configure', icon: 'ti-adjustments',
                            stype: 'Setup' },
                            { value: 'look at', label: 'Diagnose / Assess', icon: 'ti-stethoscope',
                                stype: 'Diagnostic' },
                        ];
                        const allowed = ctx._allowedTypes;
                        if (allowed && allowed.length) {
                            const map = {
                                'Install': 'install',
                                'Install / Mount': 'mount',
                                'Repair': 'fix',
                                'Diagnostic': 'look at',
                                'Assembly': 'assemble',
                                'Setup': 'set up'
                            };
                            const keep = allowed.map(t => map[t] || t).filter(Boolean);
                            return base.filter(b => keep.includes(b.value));
                        }
                        return base;
                    }
                },
                object: {
                    id: 'object',
                    icon: 'ti-tag',
                    prompt: 'What item or area?',
                    choices: () => {
                        const choices = [];
                        const cat = BLD._cat || S.intent?.category || 'other';
                        const groups = (DB.group || []).filter(g => g.category_id === cat);
                        const seen = new Set();
                        groups.forEach(g => {
                            if (seen.has(g.id)) return;
                            seen.add(g.id);
                            choices.push({
                                value: g.id,
                                label: g.display_name || g.name,
                                icon: g.icon || 'ti-folder',
                                cat: cat,
                                groupId: g.id,
                                keyword: g.name
                            });
                        });
                        // Sort by usage weight: known high-volume groups first
                        const PRIORITY = ['walls', 'doors', 'windows', 'cabinets_drawers', 'appliances',
                            'tile',
                            'furniture'
                        ];
                        choices.sort((a, b) => {
                            const pa = PRIORITY.indexOf(a.groupId);
                            const pb = PRIORITY.indexOf(b.groupId);
                            if (pa === -1 && pb === -1) return a.label.localeCompare(b.label);
                            if (pa === -1) return 1;
                            if (pb === -1) return -1;
                            return pa - pb;
                        });
                        return choices;
                    }
                },
                specific: {
                    id: 'specific',
                    icon: 'ti-details',
                    prompt: 'Be more specific?',
                    choices: () => {
                        const choices = [];
                        const groupId = BLD.object;
                        const services = servicesByGroup.get(groupId) || [];
                        const seen = new Set();
                        services.forEach(svc => {
                            const label = svc.ui_taxonomy?.display_name || svc.name || svc.id;
                            if (seen.has(label)) return;
                            seen.add(label);
                            choices.push({
                                value: svc.id,
                                label: label,
                                icon: svc.ui_taxonomy?.icon || 'ti-tool',
                                cat: BLD._cat || S.intent?.category || 'other',
                                groupId: groupId,
                                keyword: label
                            });
                        });
                        // If no services → allow free-text specific
                        if (choices.length === 0) {
                            choices.push({
                                value: BLD.object,
                                label: BLD.object,
                                icon: 'ti-pencil',
                                cat: BLD._cat || S.intent?.category || 'other',
                                groupId: groupId,
                                keyword: BLD.object
                            });
                        }
                        return choices;
                    }
                },
                condition: {
                    id: 'condition',
                    icon: 'ti-alert-triangle',
                    prompt: 'Any issue or condition? (optional)',
                    choices: () => {
                        const base = [
                            { value: null, label: 'Skip — no special condition', icon: 'ti-check' },
                            { value: 'broken', label: 'Broken / cracked', icon: 'ti-bug' },
                            { value: 'leaking', label: 'Leaking / water damage', icon: 'ti-droplet' },
                            { value: 'stuck', label: 'Stuck / jammed', icon: 'ti-lock' },
                            { value: 'clogged', label: 'Clogged / blocked', icon: 'ti-backhoe' },
                            { value: 'wobbly', label: 'Wobbly / unstable', icon: 'ti-arrows-sort' },
                            { value: 'electrical', label: 'Electrical issue', icon: 'ti-zap' },
                            { value: 'software', label: 'Software / config issue', icon: 'ti-code' },
                        ];
                        const cat = BLD._cat || S.intent?.category || 'other';
                        if (cat === 'plumbing_help') {
                            base.push({ value: 'no water', label: 'No water / low pressure', icon: 'ti-water' });
                        }
                        if (cat === 'electric_lighting') {
                            base.push({ value: 'flickering', label: 'Flickering / dimming', icon: 'ti-bolt' });
                        }
                        if (cat === 'tech_trouble') {
                            base.push({ value: 'slow', label: 'Slow / unresponsive', icon: 'ti-speed' });
                        }
                        return base;
                    }
                },
                location: {
                    id: 'location',
                    icon: 'ti-map-pin',
                    prompt: 'Where is it?',
                    choices: () => {
                        const rooms = (DB.negation_library?.nlp_location_words || ['living room', 'kitchen',
                            'bedroom', 'bathroom', 'office', 'garage', 'basement', 'attic', 'patio',
                            'deck', 'hallway', 'dining room'
                        ]);
                        const base = [{ value: null, label: 'Skip — not needed', icon: 'ti-check' }];
                        rooms.forEach(r => {
                            base.push({ value: r, label: r.charAt(0).toUpperCase() + r.slice(1),
                                icon: 'ti-home' });
                        });
                        // Fallback: if rooms list is empty, provide some defaults
                        if (rooms.length === 0) {
                            return [
                                { value: null, label: 'Skip', icon: 'ti-check' },
                                { value: 'living room', label: 'Living Room', icon: 'ti-home' },
                                { value: 'kitchen', label: 'Kitchen', icon: 'ti-cooking-pot' },
                                { value: 'bedroom', label: 'Bedroom', icon: 'ti-bed' },
                                { value: 'bathroom', label: 'Bathroom', icon: 'ti-shower' },
                                { value: 'office', label: 'Office', icon: 'ti-building' },
                            ];
                        }
                        return base;
                    }
                }
            };
            return stepDefs[sid] || null;
        }

        window._recomputeInstanceLabels = _recomputeInstanceLabels;
        window.removeFurnitureEntry = removeFurnitureEntry;
        window._computePrice = _computePrice;
        window.computeQuoteFromState = computeQuoteFromState;
        window.bldGroupToKeyword = bldGroupToKeyword;
        window.stDefaultAction = stDefaultAction;
        window.sqBuilderGetSteps = sqBuilderGetSteps;
        window.sqBuilderCurrentStep = sqBuilderCurrentStep;
    </script>

    <!-- ═══ GSAP ENHANCEMENT SCRIPT ═══ -->
    <script>
        /**
         * GSAP Enhancement — visually stunning effects layered on top of the existing site.
         * All animations are non‑destructive; they enhance without breaking core functionality.
         */
        document.addEventListener('DOMContentLoaded', function() {

            // ─── 1. GSAP LOADING SCREEN ───────────────────────────────────────────
            const loader = document.getElementById('gsap-loader');
            if (loader) {
                // Animate the loader ring with a subtle pulse
                const ring = loader.querySelector('.loader-ring');
                if (ring) {
                    gsap.to(ring, {
                        rotation: 360,
                        duration: 1.6,
                        repeat: -1,
                        ease: 'power1.inOut',
                        onUpdate: function() {
                            const progress = this.progress();
                            ring.style.boxShadow =
                                `0 0 ${30 + progress * 30}px rgba(222,0,0,${0.12 + progress * 0.18})`;
                        }
                    });
                }
                // Fade out loader after 1.8s with a smooth slide-up
                gsap.to(loader, {
                    opacity: 0,
                    y: -20,
                    duration: 0.7,
                    delay: 1.2,
                    ease: 'power2.out',
                    onComplete: function() {
                        loader.classList.add('hidden');
                        loader.style.display = 'none';
                    }
                });
            }

            // ─── 2. FLOATING PARTICLES (canvas) ──────────────────────────────────
            const canvas = document.getElementById('particles-canvas');
            if (canvas) {
                const ctx = canvas.getContext('2d');
                let w, h;
                const particles = [];
                const PARTICLE_COUNT = 55;

                function resize() {
                    w = canvas.width = window.innerWidth;
                    h = canvas.height = window.innerHeight;
                }
                window.addEventListener('resize', resize);
                resize();

                // Create particles with varied sizes & speeds
                for (let i = 0; i < PARTICLE_COUNT; i++) {
                    particles.push({
                        x: Math.random() * w,
                        y: Math.random() * h,
                        r: Math.random() * 3.5 + 1.5,
                        dx: (Math.random() - 0.5) * 0.4,
                        dy: (Math.random() - 0.5) * 0.4 - 0.08,
                        opacity: Math.random() * 0.5 + 0.15,
                        hue: Math.random() * 30 + 340, // red‑magenta range
                    });
                }

                function drawParticles() {
                    ctx.clearRect(0, 0, w, h);
                    particles.forEach(p => {
                        p.x += p.dx;
                        p.y += p.dy;
                        if (p.x < 0) p.x = w;
                        if (p.x > w) p.x = 0;
                        if (p.y < 0) p.y = h;
                        if (p.y > h) p.y = 0;

                        const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 3);
                        grad.addColorStop(0, `hsla(${p.hue}, 70%, 65%, ${p.opacity})`);
                        grad.addColorStop(1, `hsla(${p.hue + 20}, 60%, 50%, 0)`);
                        ctx.beginPath();
                        ctx.arc(p.x, p.y, p.r * 3, 0, Math.PI * 2);
                        ctx.fillStyle = grad;
                        ctx.fill();

                        // Core glow
                        ctx.beginPath();
                        ctx.arc(p.x, p.y, p.r * 0.7, 0, Math.PI * 2);
                        ctx.fillStyle = `hsla(${p.hue + 10}, 80%, 80%, ${p.opacity * 0.6})`;
                        ctx.fill();
                    });
                    requestAnimationFrame(drawParticles);
                }
                drawParticles();
            }

            // ─── 3. PAGE LOAD REVEALS ────────────────────────────────────────────
            // Fade-in all elements with .gsap-fade-in
            gsap.utils.toArray('.gsap-fade-in').forEach((el, i) => {
                gsap.fromTo(el, {
                    opacity: 0,
                    y: 32,
                    scale: 0.96,
                }, {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 0.7,
                    delay: 0.3 + i * 0.1,
                    ease: 'power3.out',
                    clearProps: 'transform,opacity',
                });
            });

            // ─── 4. STAGGERED CATEGORY CARDS ─────────────────────────────────────
            const catGrid = document.getElementById('category-card');
            if (catGrid) {
                const cards = catGrid.querySelectorAll('.category-card');
                gsap.fromTo(cards, {
                    opacity: 0,
                    y: 40,
                    scale: 0.9,
                    rotation: 2,
                }, {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    rotation: 0,
                    duration: 0.65,
                    stagger: 0.08,
                    delay: 0.5,
                    ease: 'back.out(1.4)',
                    clearProps: 'transform,opacity',
                });
            }

            // ─── 5. PROFILE IMAGE 3D TILT ────────────────────────────────────────
            const profileImg = document.querySelector('.profile-portrait-image');
            if (profileImg) {
                const container = profileImg.parentElement || document.body;
                container.addEventListener('mousemove', function(e) {
                    const rect = this.getBoundingClientRect();
                    const x = (e.clientX - rect.left) / rect.width - 0.5;
                    const y = (e.clientY - rect.top) / rect.height - 0.5;
                    gsap.to(profileImg, {
                        rotationY: x * 8,
                        rotationX: -y * 6,
                        duration: 0.6,
                        ease: 'power2.out',
                        overwrite: 'auto',
                    });
                });
                container.addEventListener('mouseleave', function() {
                    gsap.to(profileImg, {
                        rotationY: 0,
                        rotationX: 0,
                        duration: 0.8,
                        ease: 'elastic.out(1, 0.5)',
                    });
                });
                // Add subtle float that doesn't interfere with tilt
                gsap.to(profileImg, {
                    y: -8,
                    duration: 2.8,
                    repeat: -1,
                    yoyo: true,
                    ease: 'sine.inOut',
                });
            }

            // ─── 6. MAIN CARD GLOW PULSE ──────────────────────────────────────────
            const mainCard = document.getElementById('mainCard') || document.querySelector('.main-card-schedule-service');
            if (mainCard) {
                gsap.to(mainCard, {
                    boxShadow: '0 20px 50px rgba(138,6,21,0.15), 0 0 60px rgba(222,0,0,0.04)',
                    duration: 2.8,
                    repeat: -1,
                    yoyo: true,
                    ease: 'sine.inOut',
                });
            }

            // ─── 7. CONTACT BUTTON MAGNETIC + PULSE ─────────────────────────────
            const contactBtn = document.querySelector('.contact-button');
            if (contactBtn) {
                // Glow pulse
                gsap.to(contactBtn, {
                    boxShadow: '0 0 30px rgba(222,0,0,0.3), inset 0 0 20px rgba(222,0,0,0.1)',
                    duration: 2.0,
                    repeat: -1,
                    yoyo: true,
                    ease: 'sine.inOut',
                });
                // Magnetic hover (enhanced)
                const magneticArea = contactBtn.parentElement || document.body;
                magneticArea.addEventListener('mousemove', function(e) {
                    const rect = contactBtn.getBoundingClientRect();
                    const cx = rect.left + rect.width / 2;
                    const cy = rect.top + rect.height / 2;
                    const dx = (e.clientX - cx) * 0.15;
                    const dy = (e.clientY - cy) * 0.15;
                    gsap.to(contactBtn, {
                        x: dx,
                        y: dy,
                        duration: 0.3,
                        ease: 'power2.out',
                        overwrite: 'auto',
                    });
                });
                magneticArea.addEventListener('mouseleave', function() {
                    gsap.to(contactBtn, {
                        x: 0,
                        y: 0,
                        duration: 0.6,
                        ease: 'elastic.out(1, 0.4)',
                    });
                });
            }

            // ─── 8. CART FAB GLOW PULSE ──────────────────────────────────────────
            const cartFab = document.getElementById('cartFab');
            if (cartFab) {
                gsap.to(cartFab, {
                    boxShadow: '0 8px 35px rgba(138,6,21,0.5), 0 0 60px rgba(222,0,0,0.15)',
                    duration: 2.2,
                    repeat: -1,
                    yoyo: true,
                    ease: 'sine.inOut',
                });
            }

            // ─── 9. STEP DOTS ANIMATED CONNECTORS ────────────────────────────────
            const stepDots = document.querySelectorAll('.step-dot');
            stepDots.forEach((dot, i) => {
                dot.addEventListener('mouseenter', function() {
                    gsap.to(this, {
                        scale: 1.25,
                        duration: 0.25,
                        ease: 'back.out(1.7)',
                    });
                });
                dot.addEventListener('mouseleave', function() {
                    gsap.to(this, {
                        scale: 1,
                        duration: 0.4,
                        ease: 'power2.out',
                    });
                });
                // Initial subtle pulse for active
                if (dot.classList.contains('active')) {
                    gsap.to(dot, {
                        scale: 1.15,
                        duration: 1.2,
                        repeat: -1,
                        yoyo: true,
                        ease: 'sine.inOut',
                    });
                }
            });

            // ─── 10. SCROLL TRIGGER REVEALS ──────────────────────────────────────
            // Only run ScrollTrigger if the library is loaded
            if (typeof ScrollTrigger !== 'undefined') {
                gsap.registerPlugin(ScrollTrigger);

                // Service tiles (inside main card) – reveal on scroll
                const serviceTiles = document.querySelectorAll('.service-tile, .group-tile');
                serviceTiles.forEach((tile, i) => {
                    gsap.fromTo(tile, {
                        opacity: 0,
                        y: 30,
                        scale: 0.95,
                    }, {
                        opacity: 1,
                        y: 0,
                        scale: 1,
                        duration: 0.5,
                        delay: i * 0.04,
                        ease: 'power2.out',
                        scrollTrigger: {
                            trigger: tile,
                            start: 'top 90%',
                            toggleActions: 'play none none reverse',
                            // markers: false,
                        },
                        clearProps: 'transform,opacity',
                    });
                });

                // Invoice card reveal
                const invCard = document.querySelector('.main-card-invoices');
                if (invCard) {
                    gsap.fromTo(invCard, {
                        opacity: 0,
                        y: 40,
                        scale: 0.94,
                    }, {
                        opacity: 1,
                        y: 0,
                        scale: 1,
                        duration: 0.7,
                        ease: 'back.out(1.2)',
                        scrollTrigger: {
                            trigger: invCard,
                            start: 'top 85%',
                            toggleActions: 'play none none reverse',
                        },
                        clearProps: 'transform,opacity',
                    });
                }

                // Highlight box reveal
                const hBox = document.querySelector('.highlight-box');
                if (hBox) {
                    gsap.fromTo(hBox, {
                        opacity: 0,
                        y: 20,
                    }, {
                        opacity: 1,
                        y: 0,
                        duration: 0.6,
                        ease: 'power2.out',
                        scrollTrigger: {
                            trigger: hBox,
                            start: 'top 88%',
                            toggleActions: 'play none none reverse',
                        },
                        clearProps: 'transform,opacity',
                    });
                }
            }

            // ─── 11. LOGO GLOW ENHANCEMENT ──────────────────────────────────────
            const logos = document.querySelectorAll('.thandylogo, .tmk_signature img');
            logos.forEach(logo => {
                gsap.to(logo, {
                    filter: 'drop-shadow(0 0 12px rgba(222,0,0,0.3)) drop-shadow(0 0 30px rgba(222,0,0,0.08))',
                    duration: 3,
                    repeat: -1,
                    yoyo: true,
                    ease: 'sine.inOut',
                });
            });

            // ─── 12. FLOATING LOGO (footer) ─────────────────────────────────────
            const footerLogo = document.querySelector('footer img');
            if (footerLogo) {
                gsap.to(footerLogo, {
                    y: -6,
                    duration: 3.2,
                    repeat: -1,
                    yoyo: true,
                    ease: 'sine.inOut',
                });
            }

            // ─── 13. TEXT GLOW ON SMARTQUOTE PREVIEW ─────────────────────────────
            const preview = document.getElementById('sqLivePreview');
            if (preview) {
                const observer = new MutationObserver(function() {
                    const phrase = preview.querySelector('.preview-phrase');
                    if (phrase && phrase.textContent.trim().length > 0) {
                        gsap.to(phrase, {
                            color: '#8a0615',
                            duration: 0.6,
                            ease: 'power2.out',
                        });
                    }
                });
                observer.observe(preview, { childList: true, subtree: true, characterData: true });
            }

            console.log('✨ GSAP enhancements active.');
        });
    </script>

    <!-- ═══ MAIN BOOT SCRIPT (preserved from original) ═══ -->
    <script>
        (async function init() {
            try {
                const res = await fetch('https://tommichael88.github.io/booktomnyc/btnyc.json');
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                SERVICE_DATA = await res.json();
                DB = SERVICE_DATA;
                window.DB = DB;

                initNlpSets();
                refreshNlpPreviewBindings();
                cacheDOM();
                buildDataMaps(SERVICE_DATA);
                renderCategoryCards();
                initSmartQuote();
                wireGlobalEvents();

                const loadedCart = loadCart();
                State.serviceRequest = loadedCart;

                const store = window.createStore();
                window.__store = store;
                const { setCart } = window.actions;
                if (typeof setCart === 'function') {
                    store.dispatch(setCart(loadedCart));
                } else {
                    store.dispatch({ type: 'cart/SET', payload: { serviceRequest: loadedCart } });
                }

                const unsubscribeLegacy = store.bindLegacyGlobals(window);
                renderCart();

                store.subscribe((state) => {
                    try {
                        sessionStorage.setItem('booktom_cart_v2', JSON.stringify(state.cart.serviceRequest));
                    } catch (_) {}
                });

                ['intakeQuestionsContainer', 'serviceRequestSummary', 'quoteOut'].forEach(id => {
                    const el = document.getElementById(id);
                    if (el) el.style.display = 'none';
                });
                const catGrid = document.getElementById('category-card');
                if (catGrid) catGrid.style.display = 'grid';

                setViewportHeight();

                window.sqAnalyze = sqAnalyze;
                window.sqUnifiedAction = sqUnifiedAction;
                window.sqToggleBuilder = sqToggleBuilder;
                window.sqBuilderBack = sqBuilderBack;
                window.sqPickType = sqPickType;
                window.sqHandleStep2 = sqHandleStep2;
                window.sqOpenStep = sqOpenStep;
                window.sqToggleTag = sqToggleTag;
                window.sqAdjQty = sqAdjQty;
                window.sqBuildAdlib = sqBuildAdlib;
                window.sqEditAdlib = sqEditAdlib;
                window.sqConfirmAdlib = sqConfirmAdlib;
                window.sqAddToCart = sqAddToCart;
                window.sqRestart = sqRestart;
                window._sqSwitchToRecommended = _sqSwitchToRecommended;
                window._sqRevertAutoSelect = _sqRevertAutoSelect;
                window.prefillSmartQuoteFromService = prefillSmartQuoteFromService;

                window.renderRoute = function(route) {
                    window._currentRoute = route;
                    const catGrid = document.getElementById('category-card');
                    const intakeContainer = document.getElementById('intakeQuestionsContainer');
                    const summaryContainer = document.getElementById('serviceRequestSummary');
                    const quoteOut = document.getElementById('sqQuoteOut');

                    if (catGrid) catGrid.style.display = 'none';
                    if (intakeContainer) intakeContainer.style.display = 'none';
                    if (summaryContainer) summaryContainer.style.display = 'none';
                    if (quoteOut) quoteOut.style.display = 'none';

                    switch (route.uiTemplate) {
                        case 'self_quote':
                            renderSelfQuoteFromRoute(route);
                            break;
                        case 'curated_card':
                            renderCuratedCardFromRoute(route);
                            if (summaryContainer) summaryContainer.style.display = 'block';
                            break;
                        case 'legacy_flow':
                            if (intakeContainer) {
                                intakeContainer.style.display = 'block';
                                intakeContainer.innerHTML =
                                    '<div class="repair-hint">Legacy flow – please use the new UI.</div>';
                            }
                            break;
                        default:
                            if (catGrid) catGrid.style.display = 'grid';
                    }
                };

                console.log('✅ BookTOM initialized successfully.');

            } catch (err) {
                console.error('❌ BookTOM failed to initialize:', err);
                toast('Could not load services. Please refresh.', 'error');
            }
        })();
    </script>


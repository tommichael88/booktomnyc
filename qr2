        }

        function _renderOtherFlow(svc, category_id, container, prof) {
            const basePrice = svc.financial_engine?.base_price || 85;
            const groupName = (() => {
                const lastFrame = [...Breadcrumbs.stack].reverse().find(f => f.type === 'subgroup' || f.type ===
                'subgroups');
                if (lastFrame) {
